{
  "name": "gmail-quiet-labels",
  "version": "1.4.0",
  "repository": "https://github.com/alexwforsythe/gmail-quiet-labels",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "22.17.0"
  },
  "scripts": {
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --project .",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run typecheck && npm run lint:check && npm run format:check",
    "build": "tsx build.ts",
    "prepush": "npm run build",
    "push": "clasp push --force"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@gas-plugin/unplugin": "^0.1.2",
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
